# Copy this to .env.native and fill in your Railway backend URL.
# Use this when building for Capacitor (iOS / Android):
#
#   npx dotenv -e .env.native -- npm run build
#   npx cap sync
#   npx cap open ios
#
# DO NOT use this file for the Railway Docker build — that build runs without
# VITE_API_URL so API calls are same-origin relative URLs.

VITE_API_URL=https://your-railway-app.up.railway.app
