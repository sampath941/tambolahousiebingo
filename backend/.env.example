# Copy this to backend/.env for local development

# Railway Postgres URL (Railway injects this automatically in production)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Random secret for signing JWTs — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret

# CORS origins for local development (Vite dev server).
# In production the frontend is served by the same process — CORS is not needed.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
